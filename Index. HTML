<!DOCTYPE html>
<html lang="om">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Kolleejjii Poolii Tekinika Shaashamannee · Galmee Ogummaa</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', Roboto, sans-serif;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(ellipse at 40% 40%, #1b273a 0%, #0a0f1f 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px 10px;
            position: relative;
            overflow-x: hidden;
        }

        /* 🌟 ወርቃማ ፕላኔቶች እና ኮከቦች መንቀሳቀሻ */
        .golden-universe {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .planet, .star {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, #f9e076, #b8860b);
            box-shadow: 0 0 30px #ffd966, 0 0 60px #f1c40f;
            opacity: 0.4;
            animation: floatPlanet linear infinite;
        }

        .planet {
            width: 80px;
            height: 80px;
            filter: blur(2px);
        }

        .planet:nth-child(1) { top: 15%; left: 5%; width: 110px; height: 110px; animation-duration: 38s; animation-delay: -5s; }
        .planet:nth-child(2) { bottom: 20%; right: 2%; width: 150px; height: 150px; animation-duration: 52s; animation-delay: -12s; }
        .planet:nth-child(3) { top: 60%; left: 80%; width: 70px; height: 70px; animation-duration: 28s; }
        .planet:nth-child(4) { bottom: 5%; left: 15%; width: 200px; height: 200px; opacity: 0.2; animation-duration: 70s; background: #e6b422; }

        .star {
            width: 6px;
            height: 6px;
            background: #fff9e6;
            box-shadow: 0 0 12px gold;
            opacity: 0.8;
            animation: twinkleStar 4s infinite alternate;
        }

        @keyframes floatPlanet {
            0% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(40px, -25px) rotate(120deg); }
            66% { transform: translate(-30px, 35px) rotate(240deg); }
            100% { transform: translate(0, 0) rotate(360deg); }
        }

        @keyframes twinkleStar {
            0% { opacity: 0.2; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.3); }
        }

        /* 🌟 ዋና ካርድ */
        .registration-card {
            position: relative;
            z-index: 10;
            max-width: 850px;
            width: 100%;
            background: rgba(20, 30, 45, 0.9);
            backdrop-filter: blur(14px) saturate(180%);
            -webkit-backdrop-filter: blur(14px);
            border-radius: 48px 48px 40px 40px;
            border: 2px solid rgba(255, 215, 0, 0.5);
            box-shadow: 0 30px 60px rgba(0,0,0,0.7), 0 0 0 2px #f1c40f inset, 0 0 25px #f7dc6f;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.4s;
            animation: cardGlow 6s infinite alternate;
        }

        @keyframes cardGlow {
            0% { box-shadow: 0 30px 60px rgba(0,0,0,0.7), 0 0 0 2px #f1c40f inset, 0 0 25px #f1c40f; }
            100% { box-shadow: 0 40px 70px rgba(0,0,0,0.9), 0 0 0 4px #ffd966 inset, 0 0 50px #ffb347; }
        }

        .header-golden {
            background: linear-gradient(135deg, #2c3e50, #1a2634);
            padding: 28px 22px 20px;
            border-bottom: 5px solid #ffd966;
            position: relative;
            text-align: center;
        }

        .header-golden h1 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #ffedb0;
            text-shadow: 0 2px 10px #e6b422, 0 4px 20px #b8860b;
        }

        .header-golden h2 {
            font-size: 1.4rem;
            color: #ffe484;
            font-weight: 500;
            margin: 6px 0 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .badge {
            background: #f1c40f;
            color: #1a2634;
            padding: 6px 18px;
            border-radius: 40px;
            font-weight: 700;
            display: inline-block;
            box-shadow: 0 0 20px currentColor;
        }

        .content {
            padding: 24px 20px 30px;
            color: #f0f4fa;
        }

        .section-title {
            font-size: 1.3rem;
            font-weight: 600;
            border-left: 14px solid #f7d44a;
            padding-left: 18px;
            margin: 30px 0 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-shadow: 0 2px 5px #0a0f1f;
            color: #ffe68f;
        }

        .section-title i {
            font-size: 1.8rem;
            color: #fbc531;
            filter: drop-shadow(0 0 10px #ffd966);
        }

        .announcement-box {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 40px;
            padding: 22px;
            border: 2px solid #d4af37;
            backdrop-filter: blur(5px);
            font-size: 1rem;
            line-height: 1.6;
            box-shadow: 0 20px 30px -10px black;
        }

        .date-chip {
            background: #f1c40f;
            color: #000;
            font-weight: 700;
            padding: 6px 20px;
            border-radius: 60px;
            display: inline-block;
            margin-bottom: 12px;
            font-size: 0.95rem;
        }

        /* 🛡️ የደህንነት ማስጠንቀቂያ */
        .security-notice {
            background: rgba(255, 215, 0, 0.1);
            border-left: 6px solid #ffd966;
            padding: 12px 18px;
            border-radius: 20px;
            margin: 20px 0;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 15px;
            backdrop-filter: blur(5px);
        }

        .security-notice i {
            font-size: 2rem;
            color: #ffd966;
        }

        /* 📝 የግል መረጃ ማስገቢያ */
        .input-group {
            margin-bottom: 20px;
        }

        .input-label {
            font-weight: 600;
            margin-bottom: 8px;
            color: #ffdf9e;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .input-field {
            width: 100%;
            padding: 16px 20px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid #ffd966;
            border-radius: 60px;
            font-size: 1rem;
            color: white;
            outline: none;
            transition: all 0.3s;
            backdrop-filter: blur(5px);
        }

        .input-field:focus {
            background: rgba(255, 215, 0, 0.2);
            border-color: #f9e076;
            box-shadow: 0 0 20px #f7b731;
            transform: scale(1.02);
        }

        .row-duo {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        /* 🎓 የሙያ ዝርዝር (ዲፓርትመንቶች) - ሲነኩ መልካቸው ይቀየራል */
        .program-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            background: rgba(0, 0, 0, 0.5);
            padding: 22px 18px;
            border-radius: 50px;
            border: 1px solid #ffd966;
            margin-bottom: 10px;
        }

        .program-chip {
            background: linear-gradient(145deg, #3a4a5a, #2c3e50);
            color: #ffd966;
            font-weight: 600;
            padding: 12px 20px;
            border-radius: 40px;
            font-size: 0.9rem;
            box-shadow: 0 6px 0 #1a2634, 0 8px 16px black;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: 2px solid transparent;
            user-select: none;
        }

        .program-chip i {
            color: #f7b731;
            transition: transform 0.3s;
        }

        /* Hover effect */
        .program-chip:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 0 #1a2634, 0 15px 25px black;
            background: linear-gradient(145deg, #4a5a6a, #3a4a5a);
            border-color: #f7b731;
        }

        /* Active/Selected effect */
        .program-chip.selected {
            background: linear-gradient(145deg, #f9e076, #e0aF2f);
            color: #1e2a36;
            border: 2px solid white;
            box-shadow: 0 6px 0 #8b6913, 0 10px 20px black;
            transform: translateY(-2px);
        }

        .program-chip.selected i {
            color: #1e2a36;
        }

        .program-chip:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 #1a2634, 0 8px 16px black;
        }

        .program-chip small {
            font-weight: 400;
            font-size: 0.75rem;
            background: rgba(0,0,0,0.3);
            padding: 2px 8px;
            border-radius: 40px;
            margin-left: 4px;
        }

        .program-chip.selected small {
            background: rgba(255,255,255,0.3);
            color: #000;
        }

        /* 📄 ሰነዶች አፕሎድ ክፍል */
        .upload-section {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 40px;
            padding: 24px;
            border: 2px solid #ffd966;
            margin: 25px 0;
        }

        .upload-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 15px;
        }

        .upload-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 30px;
            padding: 16px;
            text-align: center;
            border: 1px dashed #ffd966;
            transition: all 0.3s;
        }

        .upload-item:hover {
            background: rgba(255, 215, 0, 0.1);
            border-style: solid;
        }

        .upload-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .upload-label i {
            font-size: 2.5rem;
            color: #ffd966;
        }

        .upload-label span {
            font-weight: 500;
        }

        .upload-label small {
            color: #aaa;
            font-size: 0.7rem;
        }

        input[type="file"] {
            display: none;
        }

        .file-name {
            font-size: 0.75rem;
            margin-top: 8px;
            color: #ffd966;
            word-break: break-all;
        }

        /* 💰 የክፍያ ክፍል የተሻሻለ */
        .payment-section {
            background: rgba(0, 0, 0, 0.6);
            border-radius: 60px;
            padding: 28px;
            border: 3px solid #ffd966;
            margin: 30px 0;
            position: relative;
            overflow: hidden;
        }

        .payment-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #ffdf99;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 20px;
        }

        .payment-amount {
            font-size: 3rem;
            font-weight: 900;
            color: #f9e076;
            text-shadow: 0 0 20px #f1c40f;
        }

        .payment-methods {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin: 20px 0;
        }

        .method-option {
            flex: 1 1 150px;
            background: rgba(255,255,255,0.1);
            border: 2px solid #ffd966;
            border-radius: 60px;
            padding: 14px;
            text-align: center;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .method-option.selected {
            background: #ffd966;
            color: #1a2634;
            box-shadow: 0 0 20px gold;
        }

        .method-option i {
            margin-right: 8px;
        }

        .payment-upload {
            margin-top: 25px;
            border-top: 2px dashed #ffd966;
            padding-top: 25px;
        }

        /* 📍 አድራሻ እና ማጠቃለያ */
        .address-universe {
            background: #0e121f;
            border-radius: 40px;
            padding: 26px;
            margin-top: 28px;
            border: 2px solid #f0c45a;
            color: #fff3d1;
        }

        .address-line {
            display: flex;
            gap: 16px;
            margin-bottom: 16px;
            font-size: 1rem;
        }

        .slogan-gold {
            text-align: center;
            font-size: 1.7rem;
            font-weight: 800;
            color: #ffe68f;
            margin-top: 20px;
            text-transform: uppercase;
            text-shadow: 0 2px 15px #f7b731;
        }

        /* 🚀 የማስረከቢያ ቁልፎች */
        .footer-submit {
            display: flex;
            gap: 20px;
            margin: 30px 0 20px;
            flex-wrap: wrap;
        }

        .submit-main, .security-btn {
            flex: 1;
            padding: 22px;
            border-radius: 120px;
            font-size: 1.5rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            transition: 0.1s ease;
            cursor: pointer;
            border: none;
            min-width: 250px;
        }

        .submit-main {
            background: #ffd966;
            color: #1e2a36;
            box-shadow: 0 15px 0 #a5721a, 0 20px 40px gold;
        }

        .security-btn {
            background: #2c3e50;
            color: #ffd966;
            border: 2px solid #ffd966;
            box-shadow: 0 15px 0 #1a2634, 0 20px 40px #000;
        }

        .submit-main:active, .security-btn:active {
            transform: translateY(10px);
            box-shadow: 0 5px 0 #a5721a, 0 20px 40px #f9e076;
        }

        .security-btn:active {
            box-shadow: 0 5px 0 #1a2634, 0 20px 40px #000;
        }

        hr {
            border: 1px solid #f7b73150;
            margin: 20px 0;
        }

        /* 📱 ሞባይል ማስተካከያ */
        @media (max-width: 600px) {
            .row-duo { grid-template-columns: 1fr; }
            .payment-title { flex-direction: column; text-align: center; }
            .footer-submit { flex-direction: column; }
            .program-chip { padding: 10px 14px; }
        }
    </style>
</head>
<body>
    <!-- ✨ ወርቃማ ፕላኔቶች -->
    <div class="golden-universe">
        <div class="planet"></div>
        <div class="planet"></div>
        <div class="planet"></div>
        <div class="planet"></div>
        <!-- ኮከቦች -->
    </div>

    <!-- 🌟 ዋና ካርድ -->
    <div class="registration-card" id="mainCard">
        <div class="header-golden">
            <h1>KOLLEEJJII POOLII<br>TEKINIKA SHAASHAMANNEE</h1>
            <h2><i class="fas fa-shield-alt"></i> ሰንድግ ነሐ ቲክክ ዝሓይ · ደህንነቱ የተጠበቀ <i class="fas fa-lock"></i></h2>
            <div class="badge"><i class="fas fa-check-circle"></i> ምዝገባ በይፋ ተጀምሯል 26/01/2018</div>
        </div>

        <div class="content">
            <!-- 🛡️ የደህንነት ማስታወቂያ -->
            <div class="security-notice">
                <i class="fas fa-shield-virus"></i>
                <div>
                    <strong>ደህንነቱ የተጠበቀ ስርዓት</strong> · የግል መረጃዎ በኢንክሪፕሽን ይጠበቃል። ፋይሎች በሚሰቀሉበት ጊዜ መጠናቸው እስከ 5MB ብቻ ነው። ተቀባይነት ያላቸው ፎርማቶች፦ PDF, JPG, PNG
                </div>
            </div>

            <!-- 👤 የግል መረጃ -->
            <div class="section-title"><i class="fas fa-user-lock"></i> Odeeffannoo dhuunfaa</div>
            <div class="row-duo">
                <div class="input-group">
                    <div class="input-label"><i class="fas fa-user-graduate"></i> Maqaa guutuu *</div>
                    <input class="input-field" type="text" placeholder="Maqaa fi Abbaa warraa" required>
                </div>
                <div class="input-group">
                    <div class="input-label"><i class="fas fa-id-card"></i> Lakk. eenyummaa *</div>
                    <input class="input-field" type="text" placeholder="ID/Passport" required>
                </div>
            </div>
            <div class="row-duo">
                <div class="input-group">
                    <div class="input-label"><i class="fas fa-phone-alt"></i> Bilbilaa *</div>
                    <input class="input-field" type="tel" placeholder="09........" pattern="[0-9]{10}" required>
                </div>
                <div class="input-group">
                    <div class="input-label"><i class="fas fa-envelope"></i> Email</div>
                    <input class="input-field" type="email" placeholder="name@domain.com">
                </div>
            </div>

            <!-- 🎓 የሙያ ምርጫ (ዲፓርትመንቶች) - ሲነኩ መልካቸው ይቀየራል -->
            <div class="section-title"><i class="fas fa-galactic-republic"></i> Ogummaa filadhu (ፕሮግራም ምረጥ)</div>
            <div class="program-grid" id="programGrid">
                <!-- ሁሉም ፕሮግራሞች ከፎቶው መሰረት -->
                <span class="program-chip" data-program="crop"><i class="fas fa-seedling"></i> Crop Production <small>I-IV</small></span>
                <span class="program-chip" data-program="animal"><i class="fas fa-horse"></i> Animal Production <small>I-IV</small></span>
                <span class="program-chip" data-program="garment"><i class="fas fa-tshirt"></i> Garment Production <small>I-IV</small></span>
                <span class="program-chip" data-program="fashion"><i class="fas fa-paint-brush"></i> Fashion Design <small>II-IV</small></span>
                <span class="program-chip" data-program="mech"><i class="fas fa-tools"></i> Mechanics <small>I-V</small></span>
                <span class="program-chip" data-program="mach"><i class="fas fa-robot"></i> Machining <small>I-IV</small></span>
                <span class="program-chip" data-program="cereal"><i class="fas fa-wheat-alt"></i> Cereal Processing <small>II-IV</small></span>
                <span class="program-chip" data-program="dairy"><i class="fas fa-cheese"></i> Dairy Product Processing <small>II-IV</small></span>
                <span class="program-chip" data-program="fruit"><i class="fas fa-apple-alt"></i> Fruit & Vegetable Processing <small>I-IV</small></span>
                <span class="program-chip" data-program="autoElec"><i class="fas fa-car-battery"></i> Automotive Electrical/Electronics <small>I-IV</small></span>
                <span class="program-chip" data-program="autoMech"><i class="fas fa-oil-can"></i> Automotive Mechanics <small>I-IV</small></span>
                <span class="program-chip" data-program="hardware"><i class="fas fa-network-wired"></i> Hardware & Networking <small>I-IV</small></span>
                <span class="program-chip" data-program="web"><i class="fas fa-code"></i> Web Dev & DB Admin <small>I-IV</small></span>
                <span class="program-chip" data-program="plumb"><i class="fas fa-wrench"></i> Plumbing Installation <small>I-IV</small></span>
                <span class="program-chip" data-program="struct"><i class="fas fa-building"></i> Structural Construction <small>I-IV</small></span>
                <span class="program-chip" data-program="finish"><i class="fas fa-paint-roller"></i> Finishing Construction <small>I-IV</small></span>
                <span class="program-chip" data-program="industrial"><i class="fas fa-industry"></i> Industrial Electrical Machines <small>I-IV</small></span>
                <span class="program-chip" data-program="cad"><i class="fas fa-draw-polygon"></i> Cadastral Surveying <small>II-IV</small></span>
                <span class="program-chip" data-program="urban"><i class="fas fa-city"></i> Urban Planning & Land Admin <small>II-IV</small></span>
            </div>

            <!-- 📄 የሰነዶች አፕሎድ ክፍል (እውነተኛ ሰነዶች) -->
            <div class="section-title"><i class="fas fa-file-upload"></i> ሰነዶች ስቀል (Upload Documents)</div>
            <div class="upload-section">
                <div class="upload-grid">
                    <!-- የ12ኛ ክፍል ውጤት -->
                    <div class="upload-item">
                        <label class="upload-label" for="grade12">
                            <i class="fas fa-file-certificate"></i>
                            <span>ሪፖርት ካርድ 12ኛ</span>
                            <small>PDF, JPG (max 5MB)</small>
                        </label>
                        <input type="file" id="grade12" accept=".pdf,.jpg,.jpeg,.png" data-max-size="5000000">
                        <div class="file-name" id="file-grade12"></div>
                    </div>
                    <!-- ትራንስክሪፕት 9-12 -->
                    <div class="upload-item">
                        <label class="upload-label" for="transcript">
                            <i class="fas fa-file-alt"></i>
                            <span>ትራንስክሪፕት 9-12</span>
                            <small>PDF (max 5MB)</small>
                        </label>
                        <input type="file" id="transcript" accept=".pdf" data-max-size="5000000">
                        <div class="file-name" id="file-transcript"></div>
                    </div>
                    <!-- መታወቂያ -->
                    <div class="upload-item">
                        <label class="upload-label" for="idCard">
                            <i class="fas fa-id-card"></i>
                            <span>የመታወቂያ ፎቶ</span>
                            <small>JPG, PNG (max 2MB)</small>
                        </label>
                        <input type="file" id="idCard" accept=".jpg,.jpeg,.png" data-max-size="2000000">
                        <div class="file-name" id="file-idCard"></div>
                    </div>
                    <!-- የዋስትና ፎቶ -->
                    <div class="upload-item">
                        <label class="upload-label" for="guarantor">
                            <i class="fas fa-handshake"></i>
                            <span>የዋስ ፎቶ (3x4)</span>
                            <small>JPG, PNG</small>
                        </label>
                        <input type="file" id="guarantor" accept=".jpg,.jpeg,.png" data-max-size="2000000">
                        <div class="file-name" id="file-guarantor"></div>
                    </div>
                </div>
                <p style="text-align: center; margin-top: 20px; color: #ffd966;"><i class="fas fa-info-circle"></i> ኦርጅናል እና ፎቶ ኮፒ ሁለቱንም ስቀል</p>
            </div>

            <!-- 💰 የተሻሻለ የክፍያ ክፍል ከክፍያ ዘዴ እና ማስረጃ አፕሎድ ጋር -->
            <div class="section-title"><i class="fas fa-coins"></i> ክፍያ (Payment)</div>
            <div class="payment-section">
                <div class="payment-title">
                    <i class="fas fa-crown"></i>
                    <span class="payment-amount">350 ETB</span>
                </div>
                <p style="margin-bottom: 15px;">እባክዎ የሚመችዎን የክፍያ ዘዴ ይምረጡ፦</p>
                
                <!-- የክፍያ ዘዴ ምርጫ -->
                <div class="payment-methods" id="paymentMethods">
                    <div class="method-option" data-method="telebirr"><i class="fas fa-mobile-alt"></i> Telebirr</div>
                    <div class="method-option" data-method="mbirr"><i class="fas fa-wifi"></i> M-Birr</div>
                    <div class="method-option" data-method="bank"><i class="fas fa-university"></i> Bank</div>
                    <div class="method-option" data-method="cash"><i class="fas fa-money-bill-wave"></i> Cash (በካምፓስ)</div>
                </div>

                <!-- የክፍያ ማስረጃ አፕሎድ -->
                <div class="payment-upload">
                    <div class="upload-item" style="background: rgba(255,215,0,0.05);">
                        <label class="upload-label" for="paymentReceipt">
                            <i class="fas fa-receipt"></i>
                            <span>የክፍያ ማስረጃ ስቀል</span>
                            <small>PDF, ስክሪንሾት (max 5MB)</small>
                        </label>
                        <input type="file" id="paymentReceipt" accept=".pdf,.jpg,.jpeg,.png" data-max-size="5000000">
                        <div class="file-name" id="file-payment"></div>
                    </div>
                </div>
            </div>

            <!-- 📍 አድራሻ እና ማረጋገጫ -->
            <div class="address-universe">
                <div class="address-line"><i class="fas fa-map-marked-alt"></i> Bulchinsa Magaalaa Shaashamannee Kutaa Magaalaa Allachee Aanaa Awaashoo</div>
                <div class="address-line"><i class="fas fa-bus"></i> Buufata Konkolaataa gara gadi siige M/B Madda Hayyootaa gaditti argamna.</div>
                <div class="address-line"><i class="fas fa-school"></i> Kolleejjii Poolii Tekinika Shaashamannee, Bakka Ogummaan itti Badhaadhan!!</div>
                <div class="slogan-gold">🔒 ደህንነቱ የተጠበቀ ምዝገባ</div>
            </div>

            <!-- 🚀 የማስረከቢያ ቁልፎች -->
            <div class="footer-submit">
                <button class="submit-main" id="submitBtn"><i class="fas fa-paper-plane"></i> አስገባ / Galmeessi</button>
                <button class="security-btn" id="securityBtn"><i class="fas fa-shield-alt"></i> የደህንነት ማረጋገጫ</button>
            </div>

            <!-- የደህንነት ማስጠንቀቂያ መልዕክት -->
            <hr>
            <div style="text-align: center; font-size: 0.8rem; color: #aaa;">
                <i class="fas fa-lock"></i> የግል መረጃዎ በምስጠራ (encryption) ይጠበቃል። ማንኛውም የውሸት መረጃ ማስገባት ወንጀል ነው።
            </div>
        </div> <!-- end content -->
    </div> <!-- end card -->

    <script>
        // 🌟 የካርድ መንቀጥቀጥ ተጨማሪ
        const card = document.getElementById('mainCard');
        card.addEventListener('touchstart', function() { this.style.transform = 'scale(1.02)'; });
        card.addEventListener('touchend', function() { this.style.transform = 'scale(1)'; });
        card.addEventListener('mouseenter', function() { this.style.transform = 'scale(1.01)'; });
        card.addEventListener('mouseleave', function() { this.style.transform = 'scale(1)'; });

        // 🎓 የሙያ ቺፖች ሲነኩ selected class መጨመር/ማስወገድ
        const programChips = document.querySelectorAll('.program-chip');
        programChips.forEach(chip => {
            chip.addEventListener('click', function() {
                // ከዚህ በፊት የነበረውን selected አስወግድ (አንድ ብቻ እንዲመረጥ)
                programChips.forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
            });

            // ለስላሳ መንቀጥቀጥ
            chip.addEventListener('touchstart', function() {
                this.style.transform = 'scale(0.95)';
            });
            chip.addEventListener('touchend', function() {
                this.style.transform = '';
            });
        });

        // 💳 የክፍያ ዘዴ ምርጫ
        const methodOptions = document.querySelectorAll('.method-option');
        methodOptions.forEach(opt => {
            opt.addEventListener('click', function() {
                methodOptions.forEach(o => o.classList.remove('selected'));
                this.classList.add('selected');
            });
        });

        // 📁 የፋይል አፕሎድ ማሳያ (የፋይል ስም ማሳየት)
        function handleFileSelect(inputId, displayId) {
            const input = document.getElementById(inputId);
            const display = document.getElementById(displayId);
            if (!input || !display) return;

            input.addEventListener('change', function() {
                if (this.files && this.files[0]) {
                    const file = this.files[0];
                    // የፋይል መጠን ማረጋገጫ
                    const maxSize = this.dataset.maxSize || 5000000;
                    if (file.size > maxSize) {
                        alert(`ማስጠንቀቂያ: የፋይል መጠን ከሚፈቀደው በላይ ነው (max ${maxSize/1000000}MB)`);
                        this.value = '';
                        display.innerText = '';
                        return;
                    }
                    display.innerText = `📎 ${file.name} (${(file.size/1024).toFixed(1)}KB)`;
                } else {
                    display.innerText = '';
                }
            });
        }

        // ለሁሉም የፋይል አፕሎድ ቦታዎች አሰራርን ይፍጠር
        handleFileSelect('grade12', 'file-grade12');
        handleFileSelect('transcript', 'file-transcript');
        handleFileSelect('idCard', 'file-idCard');
        handleFileSelect('guarantor', 'file-guarantor');
        handleFileSelect('paymentReceipt', 'file-payment');

        // 🛡️ የደህንነት ቁልፍ ሲጫኑ ማስጠንቀቂያ
        document.getElementById('securityBtn').addEventListener('click', function() {
            alert('የእርስዎ መረጃ ደህንነቱ በተጠበቀ ሁኔታ ተቀምጧል። እባክዎ ሁሉንም መረጃ በትክክል ይሙሉ።');
        });

        // 📝 የማስረከቢያ ቁልፍ ሲጫኑ ማረጋገጫ
        document.getElementById('submitBtn').addEventListener('click', function() {
            // ቀላል ማረጋገጫ
            const requiredFields = document.querySelectorAll('[required]');
            let allFilled = true;
            requiredFields.forEach(field => {
                if (!field.value) {
                    field.style.borderColor = 'red';
                    allFilled = false;
                } else {
                    field.style.borderColor = '#ffd966';
                }
            });

            if (!allFilled) {
                alert('እባክዎ ሁሉንም አስፈላጊ ቦታዎች (*) ይሙሉ።');
                return;
            }

            const selectedProgram = document.querySelector('.program-chip.selected');
            if (!selectedProgram) {
                alert('እባክዎ አንድ የሙያ መርሃ ግብር (program) ይምረጡ።');
                return;
            }

            alert('ማመልከቻዎ በደህንነቱ በተጠበቀ ሁኔታ ተልኳል! በቅርቡ የምላሽ መልእክት ይደርስዎታል።');
        });
    </script>
</body>
</html>
